# My Safer Typeless Server Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3100
HOST=0.0.0.0

# Shared password for authentication (set on first run via API or Admin Portal)
# Leave empty to be prompted on first launch
SHARED_PASSWORD=

# Groq API (primary STT engine)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=whisper-large-v3

# Local whisper.cpp (fallback STT)
WHISPER_CPP_PATH=whisper-cpp
WHISPER_MODEL_PATH=

# Ollama (text refinement)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Language: zh-TW or en
DEFAULT_LANGUAGE=zh-TW

# Audio
AUDIO_UPLOAD_DIR=./audio-uploads
KEEP_AUDIO_FILES=false
