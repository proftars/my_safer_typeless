{
  "name": "my-safer-typeless-electron",
  "version": "1.0.0",
  "description": "Electron menu bar app for voice-to-text transcription",
  "main": "./dist/main.js",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"tsc --watch\" \"electron .\"",
    "build": "tsc",
    "start": "electron .",
    "package": "electron-builder --publish never",
    "package:mac": "electron-builder --mac --publish never",
    "dist": "npm run build && npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/electron": "^1.6.10",
    "typescript": "^5.3.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-record-lpcm16": "^1.0.0",
    "wav": "^1.0.2",
    "axios": "^1.6.2"
  },
  "build": {
    "appId": "com.safertypeless.app",
    "productName": "My Safer Typeless",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  }
}
